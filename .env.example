# Copy to .env and adjust locally. Do not commit real values.
# See AGENTS.md and README.md for run instructions.
#
# Audit: backend (process.env), frontend (Vite + import.meta.env), mcp-server (process.env).
# Only VITE_* keys are exposed to the browser bundle; everything else is server-side.

# --- Backend (backend/) — process.env ---
# NODE_ENV=development
# PORT=3003
# HOST=0.0.0.0
# SWAGGER_ENABLED=true
# API_BASE_URL=http://localhost:3000

# --- Frontend (frontend/) — Vite ---
# Used in vite.config.ts (process.env) and client code (import.meta.env.VITE_*).
# VITE_BACKEND_PORT=3003
#
# Built into Vite (do not define in .env): import.meta.env.DEV, PROD, MODE, SSR, etc.

# --- MCP server (mcp-server/) — process.env ---
# AUTOMFLOWS_BACKEND_URL=http://localhost:3003
# AUTOMFLOWS_WORKFLOWS_PATH=
# AUTOMFLOWS_VERBOSE=false
# LLM_PROVIDER=none
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4
# LOCAL_LLM_BASE_URL=http://localhost:11434
# LOCAL_LLM_MODEL=llama3
