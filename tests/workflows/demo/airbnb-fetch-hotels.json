      },
      "data": {
        "type": "javascriptCode",
        "label": "Build CSV row",
        "code": "const name = (context.getData('listingName') || '').replace(/[\\r\\n]+/g, ' ').trim();\nconst cardText = context.getData('cardText') || '';\nconst link = context.getData('listingLink') || '';\nconst priceMatch = cardText.match(/[\\$\\u20b9\\u00a3\\u20ac]\\s?[\\d,]+/);\nconst price = priceMatch ? priceMatch[0].trim() : '';\nconst fullLink = link && link.startsWith('http') ? link : 'https://www.airbnb.com' + (link || '');\nconst row = {\n  name: name,\n  price: price,\n  link: fullLink\n};\ncontext.setData('rowToAppend', [row]);",
        "isTest": true,
        "searchHighlighted": false,
        "isPinned": false,
        "isMinimized": false,
        "width": 200
      }
