        "width": 280,
        "searchHighlighted": false,
        "jsScript": "(function() {\n  'use strict';\n  const MOBILE_WIDTH = 390;\n  const MOBILE_HEIGHT = 844;\n  const MOBILE_USER_AGENT = 'Mozilla/5.0 (iPhone; CPU iPhone OS 16_6 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.6 Mobile/15E148 Safari/604.1';\n  Object.defineProperty(window, 'innerWidth', { get: () => MOBILE_WIDTH, configurable: true, enumerable: true });\n  Object.defineProperty(window, 'innerHeight', { get: () => MOBILE_HEIGHT, configurable: true, enumerable: true });\n  Object.defineProperty(window, 'outerWidth', { get: () => MOBILE_WIDTH, configurable: true, enumerable: true });\n  Object.defineProperty(window, 'outerHeight', { get: () => MOBILE_HEIGHT, configurable: true, enumerable: true });\n  Object.defineProperty(screen, 'width', { get: () => MOBILE_WIDTH, configurable: true, enumerable: true });\n  Object.defineProperty(screen, 'height', { get: () => MOBILE_HEIGHT, configurable: true, enumerable: true });\n  Object.defineProperty(screen, 'availWidth', { get: () => MOBILE_WIDTH, configurable: true, enumerable: true });\n  Object.defineProperty(screen, 'availHeight', { get: () => MOBILE_HEIGHT - 44, configurable: true, enumerable: true });\n  Object.defineProperty(navigator, 'userAgent', { get: () => MOBILE_USER_AGENT, configurable: true, enumerable: true });\n  Object.defineProperty(navigator, 'platform', { get: () => 'iPhone', configurable: true, enumerable: true });\n  Object.defineProperty(navigator, 'maxTouchPoints', { get: () => 5, configurable: true, enumerable: true });\n  Object.defineProperty(navigator, 'hardwareConcurrency', { get: () => 6, configurable: true, enumerable: true });\n  if ('deviceMemory' in navigator) { Object.defineProperty(navigator, 'deviceMemory', { get: () => 4, configurable: true, enumerable: true }); }\n  if ('connection' in navigator) {\n    const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;\n    if (connection) { Object.defineProperty(connection, 'effectiveType', { get: () => '4g', configurable: true, enumerable: true }); }\n  }\n  if (!('ontouchstart' in window)) { Object.defineProperty(window, 'ontouchstart', { get: () => null, set: () => {}, configurable: true, enumerable: true }); }\n  const originalMatchMedia = window.matchMedia;\n  window.matchMedia = function(query) {\n    if (query.includes('max-width')) {\n      const match = query.match(/max-width:\\s*(\\d+)px/);\n      if (match && parseInt(match[1]) >= MOBILE_WIDTH) {\n        return { matches: true, media: query, onchange: null, addListener: function() {}, removeListener: function() {}, addEventListener: function() {}, removeEventListener: function() {}, dispatchEvent: function() { return true; } };\n      }\n    }\n    return originalMatchMedia.call(window, query);\n  };\n  if (document.documentElement) {\n    let viewportMeta = document.querySelector('meta[name=\"viewport\"]');\n    if (!viewportMeta) { viewportMeta = document.createElement('meta'); viewportMeta.setAttribute('name', 'viewport'); document.head.appendChild(viewportMeta); }\n    viewportMeta.setAttribute('content', `width=${MOBILE_WIDTH}, initial-scale=1.0, maximum-scale=1.0, user-scalable=no`);\n  }\n  console.log(`[Mobile Emulation] Viewport set to ${MOBILE_WIDTH}x${MOBILE_HEIGHT}`);\n})();\n"
