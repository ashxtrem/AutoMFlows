    {
      "id": "jsBuildRow",
      "type": "javascriptCode",
      "position": { "x": 1315, "y": 700 },
      "data": {
        "type": "javascriptCode",
        "label": "Build CSV row",
        "code": "const idx = context.getVariable('index') || 0;\nconst text = context.getData('cardText') || '';\nconst link = context.getData('productLink') || '';\nconst lines = text.split('\\n').map(l => l.trim()).filter(Boolean);\nlet productName = '';\nfor (const line of lines) {\n  if (line.length > 10 && !line.match(/^(Sponsored|Best Seller|\\d+ out of|\\u20b9|FREE|Save|Get it)/i)) {\n    productName = line.substring(0, 200);\n    break;\n  }\n}\nif (!productName && lines.length > 0) productName = lines[0].substring(0, 200);\nconst ratingMatch = text.match(/(\\d+\\.?\\d*)\\s*out of\\s*5/);\nconst rating = ratingMatch ? ratingMatch[1] : '';\nconst priceMatch = text.match(/\\u20b9([\\d,]+)/);\nconst price = priceMatch ? '\\u20b9' + priceMatch[1] : '';\nconst fullLink = link && link.startsWith('http') ? link : 'https://www.amazon.in' + (link || '');\nconst row = {\n  index: idx + 1,\n  productName: productName.replace(/[\\r\\n]+/g, ' ').trim(),\n  rating: rating,\n  price: price,\n  productLink: fullLink\n};\ncontext.setData('bookRowToAppend', [row]);",
        "isTest": false,
        "searchHighlighted": false,
        "isPinned": false
      }
