    {
      "id": "dataExtractor-1",
      "type": "dataExtractor",
      "position": {
        "x": 1315,
        "y": 450
      },
      "data": {
        "type": "dataExtractor",
        "label": "Extract Book Data",
        "containerSelector": "div.s-result-item.s-asin[data-component-type='s-search-result']",
        "containerSelectorType": "css",
        "fields": [
          {
            "name": "productName",
            "selector": "h2 span",
            "selectorType": "css",
            "extract": "text"
          },
          {
            "name": "rating",
            "selector": "a[aria-label*='out of 5 stars']",
            "selectorType": "css",
            "extract": "attribute",
            "attribute": "aria-label"
          },
          {
            "name": "price",
            "selector": "span.a-price span.a-offscreen",
            "selectorType": "css",
            "extract": "text"
          },
          {
            "name": "productLink",
            "selector": "a[href*='/dp/']",
            "selectorType": "css",
            "extract": "attribute",
            "attribute": "href"
          }
        ],
        "outputVariable": "extractedBooks",
        "limit": 20,
        "timeout": 30000,
        "waitForSelector": true,
        "isTest": false,
        "isPinned": false,
        "searchHighlighted": false,
        "isMinimized": false,
        "width": 400,
        "saveToCSV": true,
        "csvFilePath": "tests\\output\\amazon_books_direct.csv"
      }
    },
    {
      "id": "smartExtractor-1",
      "type": "smartExtractor",
      "position": {
        "x": 1400,
        "y": 680
      },
      "data": {
        "type": "smartExtractor",
        "label": "Smart Extract All Links",
        "mode": "tables",
        "outputVariable": "smartLinks",
        "includeMetadata": true,
        "limit": 50,
        "timeout": 30000,
        "isTest": false,
        "isPinned": false,
        "searchHighlighted": false,
        "isMinimized": false,
        "width": 300
      }
    },
    {
      "id": "jsTransformSmart",
      "type": "javascriptCode",
      "position": {
        "x": 1840,
        "y": 510
      },
      "data": {
        "type": "javascriptCode",
        "label": "Transform smart links",
        "code": "const links = context.getData('smartLinks') || [];\nconst rows = links.map((link) => ({\n  text: (link.text || '').replace(/[\\r\\n]+/g, ' ').trim(),\n  href: link.href || '',\n  visible: link.visible !== undefined ? String(link.visible) : ''\n})).filter(r => r.text || r.href);\ncontext.setData('smartLinkRows', rows);",
        "isTest": false,
        "searchHighlighted": false,
        "isPinned": false,
        "isMinimized": false,
        "width": 400
      }
    },
