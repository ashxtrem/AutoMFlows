        "y": 2480
      },
      "data": {
        "type": "elementQuery",
        "label": "Get listing link",
        "action": "getAttribute",
        "selector": "((//div[@data-testid=\"card-container\"])[${data.cardIndex}]//a)[1]",
        "selectorType": "xpath",
        "attributeName": "href",
        "timeout": 10000,
        "outputVariable": "listingLink",
        "isTest": true,
        "searchHighlighted": false,
        "isPinned": false
